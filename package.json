{
  "name": "mcpmap",
  "version": "0.0.0",
  "private": true,
  "description": "A visual map of the Model Context Protocol spec",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "start": "node .output/server/index.mjs",
    "preview": "vp preview",
    "deploy": "vp build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:watch": "vp test",
    "lint": "vp lint",
    "format": "vp fmt --write .",
    "format:check": "vp fmt --check .",
    "pipeline:fetch": "bun run src/pipeline/fetch.ts",
    "pipeline:build": "bun run src/pipeline/build.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.30",
    "@xyflow/react": "^12.11.2",
    "elkjs": "^0.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "0.2.5",
    "vitest": "4.1.10",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vitest": "4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
